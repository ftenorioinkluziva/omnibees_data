SHELL=/bin/bash

# Coleta de precos da watchlist - 4x/dia (00h, 06h, 12h, 18h UTC)
0 0,6,12,18 * * * . /etc/environment; cd /app && echo "=== START $(date) ===" >> /var/log/omnibees_prices.log && python cli.py prices --watchlist-only --workers 5 --delay 0.3 >> /var/log/omnibees_prices.log 2>&1 && echo "=== END $(date) ===" >> /var/log/omnibees_prices.log

# Health check - a cada hora
0 * * * * . /etc/environment; cd /app && python cli.py healthcheck >> /var/log/omnibees_health.log 2>&1

