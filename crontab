0 3 * * 0 cd /app && python cli.py scrape --start 0 --end 9999 --country Brasil --delay 1.0 >> /var/log/omnibees_scrape.log 2>&1

# Health check - a cada hora
0 * * * * cd /app && python cli.py healthcheck >> /var/log/omnibees_health.log 2>&1

